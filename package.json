{
  "name": "agentspace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"NODE_TLS_REJECT_UNAUTHORIZED=0 tsx watch server/index.ts\" \"vite\"",
    "tunnel": "npx localtunnel --port 3001",
    "dev:server": "NODE_TLS_REJECT_UNAUTHORIZED=0 tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "test": "playwright test"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
